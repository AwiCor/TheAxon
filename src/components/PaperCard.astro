---
import type { Paper } from '../lib/papers';
import { readingTime } from '../lib/papers';
import { SECTIONS } from '../lib/sections';
import FormattedDate from './FormattedDate.astro';

interface Props {
  paper: Paper;
  headingLevel?: 2 | 3;
}
const { paper, headingLevel = 2 } = Astro.props;
const { title, abstract, author, date, section, pdf } = paper.data;
const s = SECTIONS[section];
const Heading = `h${headingLevel}` as const;
const minutes = readingTime(paper.body);
const badge = pdf ? 'PDF' : `${minutes} min`;
---

<article class="card" style={`--cat: var(--${s.color})`}>
  <a class="card__link" href={`/papers/${paper.id}/`} aria-label={`Read paper: ${title}`}>
    <div class="card__cover">
      <span class="card__initial" aria-hidden="true">{s.title[0]}</span>
      <span class="card__badge">{badge}</span>
    </div>
    <div class="card__body">
      <div class="card__meta">
        <span class="card__cat">{s.title}</span>
        <span class="card__dot" aria-hidden="true"></span>
        <span class="card__date"><FormattedDate date={date} variant="short" /></span>
      </div>
      <Heading class="card__title">{title}</Heading>
      <p class="card__abstract">{abstract}</p>
      <p class="card__author">{author}</p>
    </div>
  </a>
</article>

<style>
  .card__link { display: block; color: inherit; }
  .card__cover {
    position: relative;
    aspect-ratio: 3 / 2;
    border-radius: var(--radius);
    overflow: hidden;
    background:
      radial-gradient(120% 130% at 15% 12%, hsl(var(--cat) / 0.16), transparent 60%),
      hsl(var(--muted));
    border: 1px solid hsl(var(--border));
    display: flex; align-items: center; justify-content: center;
  }
  .card__initial {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(3.5rem, 8vw, 5rem);
    color: hsl(var(--cat)); opacity: 0.22; line-height: 1;
    transition: transform 0.8s cubic-bezier(0.22, 0.61, 0.36, 1), opacity 0.4s ease;
  }
  .card__link:hover .card__initial { transform: scale(1.06); opacity: 0.3; }
  .card__badge {
    position: absolute; bottom: 0.6rem; right: 0.6rem;
    background: hsl(var(--background) / 0.8); backdrop-filter: blur(4px);
    color: hsl(var(--foreground) / 0.9);
    font-family: var(--font-mono); font-size: 0.62rem;
    padding: 0.2rem 0.5rem; border-radius: 4px;
    letter-spacing: 0.04em;
  }

  .card__body { padding-top: var(--space-4); }
  .card__meta { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.4rem; }
  .card__cat {
    font-family: var(--font-mono); font-size: 0.62rem;
    text-transform: uppercase; letter-spacing: 0.18em; color: hsl(var(--cat));
  }
  .card__dot { width: 3px; height: 3px; border-radius: 9999px; background: hsl(var(--muted-foreground) / 0.4); }
  .card__date {
    font-family: var(--font-mono); font-size: 0.62rem;
    text-transform: uppercase; letter-spacing: 0.14em; color: hsl(var(--muted-foreground));
  }
  .card__title {
    font-size: 1.3rem; line-height: 1.2; letter-spacing: -0.01em;
    transition: color 0.2s ease;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
  }
  .card__link:hover .card__title { color: hsl(var(--primary)); }
  .card__abstract {
    font-family: var(--font-serif); font-size: 0.95rem; line-height: 1.55;
    color: hsl(var(--muted-foreground)); margin-top: 0.5rem;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .card__author {
    font-family: var(--font-mono); font-size: 0.72rem;
    color: hsl(var(--muted-foreground) / 0.85); margin-top: 0.75rem;
  }
</style>
