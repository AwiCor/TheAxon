---
/**
 * Reading progress drawn as a laboratory test tube, fixed at right-centre on
 * large screens. Violet liquid rises as the reader scrolls. Full ARIA
 * progressbar semantics; ported from the original React component.
 */
---
<div
  class="test-tube"
  aria-label="Reading progress"
  role="progressbar"
  aria-valuenow="0"
  aria-valuemin="0"
  aria-valuemax="100"
>
  <span class="test-tube__pct meta" data-pct>0%</span>
  <svg width="26" height="260" viewBox="0 0 26 260" fill="none" focusable="false">
    <defs>
      <clipPath id="tube-clip">
        <path d="M4 14 L4 220 Q4 232 13 232 Q22 232 22 220 L22 14 Z" />
      </clipPath>
      <linearGradient id="liquid-gradient" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#a78bfa" stop-opacity="0.7" />
        <stop offset="100%" stop-color="#7c6fff" stop-opacity="1" />
      </linearGradient>
    </defs>
    <rect x="1" y="8" width="24" height="7" rx="3" fill="none" stroke="currentColor" stroke-opacity="0.2" stroke-width="1.5" />
    <path d="M4 14 L4 220 Q4 232 13 232 Q22 232 22 220 L22 14" fill="none" stroke="currentColor" stroke-opacity="0.18" stroke-width="1.5" />
    <path d="M5 14 L5 220 Q5 230 13 230 Q21 230 21 220 L21 14" fill="white" fill-opacity="0.03" />
    <g clip-path="url(#tube-clip)">
      <rect data-liquid x="4" y="232" width="18" height="12" fill="url(#liquid-gradient)" />
    </g>
    <rect x="6" y="15" width="2.5" height="198" rx="1.25" fill="white" fill-opacity="0.07" />
    <line x1="18" y1="170" x2="22" y2="170" stroke="currentColor" stroke-opacity="0.2" stroke-width="1" />
    <line x1="18" y1="120" x2="22" y2="120" stroke="currentColor" stroke-opacity="0.2" stroke-width="1" />
    <line x1="18" y1="70" x2="22" y2="70" stroke="currentColor" stroke-opacity="0.2" stroke-width="1" />
  </svg>
  <span class="test-tube__label meta">read</span>
</div>

<style>
  .test-tube {
    position: fixed; right: 1.25rem; top: 50%;
    transform: translateY(-50%);
    z-index: 40;
    display: none;
    flex-direction: column; align-items: center; gap: 0.5rem;
    pointer-events: none;
    color: hsl(var(--muted-foreground));
    filter: drop-shadow(0 0 8px rgba(124, 111, 255, 0.35));
  }
  @media (min-width: 1024px) { .test-tube { display: flex; } }
  .test-tube__pct { font-size: 9px; letter-spacing: 0.15em; opacity: 0; transition: opacity 0.5s ease; }
  .test-tube__label { font-size: 9px; letter-spacing: 0.15em; }
  [data-liquid] { transition: y 0.35s ease, height 0.35s ease; }
</style>

<script is:inline>
  (function () {
    var root = document.querySelector('.test-tube');
    if (!root) return;
    var liquid = root.querySelector('[data-liquid]');
    var pctEl = root.querySelector('[data-pct]');
    var TUBE = 200, BOTTOM = 232;
    var ticking = false;
    function update() {
      ticking = false;
      var docH = document.documentElement.scrollHeight - window.innerHeight;
      var pct = docH > 0 ? Math.min(100, Math.max(0, (window.scrollY / docH) * 100)) : 0;
      var lh = (pct / 100) * TUBE;
      liquid.setAttribute('y', (BOTTOM - lh).toFixed(1));
      liquid.setAttribute('height', (lh + 12).toFixed(1));
      var r = Math.round(pct);
      pctEl.textContent = r + '%';
      pctEl.style.opacity = pct > 2 ? '1' : '0';
      root.setAttribute('aria-valuenow', String(r));
    }
    function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(update); } }
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  })();
</script>
