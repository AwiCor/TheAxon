---
import { SECTIONS, type SectionId } from '../lib/sections';
import { SITE_TITLE } from '../lib/site';
import ThemeToggle from './ThemeToggle.astro';

const sections = Object.entries(SECTIONS) as [SectionId, (typeof SECTIONS)[SectionId]][];
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="wordmark" href="/" aria-label={`${SITE_TITLE} — home`}>The Axon</a>

    <span class="site-header__div" aria-hidden="true"></span>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {sections.map(([id, s]) => (
          <li>
            <a href={`/${id}`} aria-current={isActive(`/${id}`) ? 'page' : undefined}>
              <span class="dot" style={`--dot: var(--${s.color})`} data-active={isActive(`/${id}`)}></span>
              {s.title}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="site-header__spacer"></div>

    <a class="site-nav__about" href="/about" aria-current={isActive('/about') ? 'page' : undefined}>About</a>
    <a class="site-nav__editor" href="/admin/" title="Editor — sign in to write" aria-label="Editor — sign in to write">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 20h9" />
        <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z" />
      </svg>
    </a>
    <ThemeToggle />
  </div>
</header>

<style>
  .site-header {
    position: sticky; top: 0; z-index: 50;
    background: hsl(var(--background) / 0.85);
    backdrop-filter: saturate(1.4) blur(14px);
    border-bottom: 1px solid hsl(var(--border));
    padding-top: env(safe-area-inset-top);
  }
  .site-header__inner {
    height: 3.5rem;
    max-width: var(--page-max);
    margin-inline: auto;
    padding-inline: var(--gutter);
    display: flex; align-items: center; gap: 1rem;
  }
  .wordmark {
    font-family: var(--font-display);
    font-size: 1.4rem; font-weight: 600; letter-spacing: -0.01em;
    color: hsl(var(--foreground)); flex-shrink: 0; line-height: 1;
  }
  .site-header__div { width: 1px; height: 1.25rem; background: hsl(var(--border)); }
  @media (max-width: 40rem) { .site-header__div { display: none; } }

  .site-nav ul { display: flex; align-items: center; gap: 0.25rem; list-style: none; padding: 0; }
  .site-nav a {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.4rem 0.75rem; border-radius: 9999px;
    font-family: var(--font-sans); font-size: 0.8rem;
    color: hsl(var(--muted-foreground)); white-space: nowrap;
  }
  .site-nav a:hover { color: hsl(var(--foreground)); }
  .site-nav a[aria-current='page'] { color: hsl(var(--foreground)); }
  .dot { width: 0.375rem; height: 0.375rem; border-radius: 9999px; background: hsl(var(--dot)); opacity: 0; transition: opacity 0.2s ease; }
  .dot[data-active='true'] { opacity: 1; }
  .site-nav a:hover .dot { opacity: 0.6; }

  .site-header__spacer { flex: 1; }

  .site-nav__about {
    font-family: var(--font-sans); font-size: 0.8rem;
    color: hsl(var(--muted-foreground)); padding: 0.4rem 0.5rem;
  }
  .site-nav__about:hover, .site-nav__about[aria-current='page'] { color: hsl(var(--foreground)); }

  .site-nav__editor {
    display: inline-flex; align-items: center; justify-content: center;
    width: 2.25rem; height: 2.25rem; border-radius: 9999px;
    color: hsl(var(--muted-foreground)); flex-shrink: 0;
  }
  .site-nav__editor:hover { color: hsl(var(--foreground)); background: hsl(var(--muted)); }

  @media (max-width: 30rem) {
    .site-nav a { padding-inline: 0.5rem; }
    .site-nav__about { display: none; }
  }
</style>
