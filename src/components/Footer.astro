---
import { SECTIONS, type SectionId } from '../lib/sections';
import { SITE_TITLE, SITE_TAGLINE } from '../lib/site';

const sections = Object.entries(SECTIONS) as [SectionId, (typeof SECTIONS)[SectionId]][];
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="site-footer__inner">
    <div class="site-footer__brand">
      <a class="site-footer__word" href="/">{SITE_TITLE}</a>
      <p class="site-footer__tag">{SITE_TAGLINE}</p>
    </div>
    <nav class="site-footer__nav" aria-label="Footer">
      {sections.map(([id, s]) => (
        <a class="link-underline" href={`/${id}`}>{s.title}</a>
      ))}
      <a class="link-underline" href="/about">About</a>
      <a class="link-underline" href="/rss.xml">RSS</a>
    </nav>
  </div>
  <div class="site-footer__legal">
    <p class="eyebrow">© {year} The Axon — all papers the work of their authors.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-9);
    border-top: 1px solid hsl(var(--border));
  }
  .site-footer__inner {
    max-width: var(--page-max);
    margin-inline: auto;
    padding: var(--space-7) var(--gutter) 0;
    display: flex; flex-wrap: wrap; gap: var(--space-5) var(--space-6);
    justify-content: space-between; align-items: baseline;
  }
  .site-footer__word {
    font-family: var(--font-display); font-weight: 600;
    font-size: 1.25rem; color: hsl(var(--foreground)); letter-spacing: -0.01em;
  }
  .site-footer__tag {
    font-family: var(--font-serif); font-style: italic;
    font-size: 0.9rem; color: hsl(var(--muted-foreground)); margin-top: 0.25rem;
  }
  .site-footer__nav { display: flex; flex-wrap: wrap; gap: var(--space-4); }
  .site-footer__nav a { font-size: 0.8rem; color: hsl(var(--muted-foreground)); }
  .site-footer__nav a:hover { color: hsl(var(--foreground)); }
  .site-footer__legal {
    max-width: var(--page-max);
    margin-inline: auto;
    padding: var(--space-6) var(--gutter) var(--space-6);
  }
</style>
